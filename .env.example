# Base URL of the Iterable environment to test against
# Production: https://app.iterable.com (default)
# Staging:    https://web.stg-itbl.co
# Dev:        https://web.dev-itbl.co (or your dev URL)
BASE_URL=https://app.iterable.com

# Iterable session cookie (from browser devtools → Application → Cookies)
# Must come from the SAME environment as BASE_URL
ITERABLE_SESSION=eyJhbGci...your-session-cookie-here

# XSRF token (from browser devtools → Application → Cookies)
XSRF_TOKEN=abc123...your-xsrf-token-here

# Browser mode: "headed" or "headless" (default: headed)
BROWSER_MODE=headed

# Viewport dimensions (default: 1440x900)
VIEWPORT_WIDTH=1440
VIEWPORT_HEIGHT=900
