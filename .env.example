# Environment: "staging" or "production" (default: staging)
ENV=staging

# Base URL — auto-set from ENV if not specified
# Staging:    https://app.stg-itbl.co
# Production: https://app.iterable.com
# BASE_URL=https://app.stg-itbl.co

# Iterable session cookie (from browser devtools → Application → Cookies)
ITERABLE_SESSION=eyJhbGci...your-session-cookie-here

# XSRF token (from browser devtools → Application → Cookies)
XSRF_TOKEN=abc123...your-xsrf-token-here

# Browser mode: "headed" or "headless" (default: headed)
BROWSER_MODE=headed

# Viewport dimensions (default: 1440x900)
VIEWPORT_WIDTH=1440
VIEWPORT_HEIGHT=900
